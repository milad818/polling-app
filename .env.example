# =============================================================================
# .env.example – Environment variable template
#
# Copy to .env and fill in the values:
#   cp .env.example .env
#
# The .env file is git-ignored.  NEVER commit real secrets to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the MySQL root user.
# Used by both:
#   • the MySQL container (MYSQL_ROOT_PASSWORD)
#   • the Spring Boot backend (DB_PASSWORD placeholder in application.properties)
DB_PASSWORD=change_me_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens.
# Must be at least 32 characters for HS256.
# Generate a strong value with:  openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# ── AWS RDS (production only) ─────────────────────────────────────────────────
RDS_HOSTNAME=YOUR_RDS_ENDPOINT
RDS_PORT=3306
RDS_DB_NAME=polling-app
RDS_USERNAME=admin

# ── Docker images (set by CI/CD on EC2, do not set locally) ────────────────
# BACKEND_IMAGE=123456789.dkr.ecr.us-east-1.amazonaws.com/polling-app-backend:latest
# FRONTEND_IMAGE=123456789.dkr.ecr.us-east-1.amazonaws.com/polling-app-frontend:latest

# ── CORS (optional) ───────────────────────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=http://localhost:4200
