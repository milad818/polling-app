<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle configuration for pollingapp.
  Focuses on rules that add real value without overlapping with Spotless
  (which already handles formatting, indentation, and import ordering).
-->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java"/>

  <!-- Allow @SuppressWarnings to suppress individual rules when necessary -->
  <module name="SuppressWarningsFilter"/>

  <module name="TreeWalker">
    <module name="SuppressWarningsHolder"/>

    <!-- ── Imports ─────────────────────────────────────────────────── -->
    <!--
      No wildcard type imports: import java.util.* is forbidden.
      Static star imports (e.g. import static org.mockito.Mockito.*) are
      allowed — Mockito/AssertJ are designed to be used this way in tests.
    -->
    <module name="AvoidStarImport">
      <property name="allowStaticMemberImports" value="true"/>
    </module>
    <!-- Unused imports must be removed (Spotless also enforces this) -->
    <module name="UnusedImports"/>
    <!-- No redundant imports of java.lang or duplicates -->
    <module name="RedundantImport"/>

    <!-- ── Blocks ──────────────────────────────────────────────────── -->
    <!-- An empty catch block must contain at least a comment explaining why -->
    <module name="EmptyCatchBlock">
      <property name="exceptionVariableName" value="expected|ignored"/>
    </module>

    <!-- ── Code quality ───────────────────────────────────────────── -->
    <!-- Avoid duplicate string literals (use a constant instead) -->
    <!-- Disabled: Lombok/Spring annotations often repeat strings innocuously -->

    <!-- String#equals("literal") should be "literal".equals(string) -->
    <module name="EqualsAvoidNull"/>

    <!-- Avoid empty statements (lone semicolons) -->
    <module name="EmptyStatement"/>

    <!-- Detects assignments inside sub-expressions, e.g. if (a = b) -->
    <module name="InnerAssignment"/>
  </module>

</module>
